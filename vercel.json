{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "gdp-prototype--main/dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/auth/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/gps/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/trips/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/alerts/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/predict/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/gdp-prototype--main/dist/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py",
      "check": true
    },
    {
      "src": "/(.*)",
      "dest": "gdp-prototype--main/dist/index.html"
    }
  ]
}
